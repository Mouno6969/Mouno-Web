generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Platform {
  TELEGRAM
  DISCORD
  TWITTER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Promoter {
  id                 Int                 @id @default(autoincrement())
  name               String
  handle             String?
  code               String              @unique
  solWallet          String?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  outboundClicks     OutboundClick[]
  referralClaims     ReferralClaim[]
  withdrawalRequests WithdrawalRequest[]
}

model RewardPool {
  id            Int      @id @default(1)
  amount        String   @default("")
  description   String   @default("")
  active        Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model OutboundClick {
  id          Int      @id @default(autoincrement())
  promoterId  Int?
  code        String
  platform    Platform
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())
  promoter    Promoter? @relation(fields: [promoterId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([platform])
  @@index([createdAt])
}

model ReferralClaim {
  id             Int          @id @default(autoincrement())
  promoterId     Int?
  code           String
  displayName    String?
  contactHandle  String?
  solWallet      String
  status         ReviewStatus @default(PENDING)
  approvedAmount String?
  adminNote      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  promoter       Promoter?    @relation(fields: [promoterId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([status])
}

model WithdrawalRequest {
  id              Int              @id @default(autoincrement())
  promoterId      Int?
  code            String
  solWallet       String
  requestedAmount String
  status          WithdrawalStatus @default(PENDING)
  message         String?
  adminNote       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  promoter        Promoter?        @relation(fields: [promoterId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([status])
}
